           RowBox[{"[", "katilimBo", "]"}], "]"}], "]"}]}], "}"}], 
       "\[Transpose]"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"katilimB", "[", 
          RowBox[{"[", "katilimBo", "]"}], "]"}], ",", 
         RowBox[{"Accumulate", "[", 
          RowBox[{"chpoyB", "[", 
           RowBox[{"[", "katilimBo", "]"}], "]"}], "]"}]}], "}"}], 
       "\[Transpose]"}]}], "\[IndentingNewLine]", "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", "Full"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{
     "sehir", "<>", 
      "\"\<\\nKat\[DotlessI]l\[DotlessI]m oran\[DotlessI]na g\[ODoubleDot]re \
k\[UDoubleDot]m\[UDoubleDot]latif oy oranlar\[DotlessI]\>\""}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotLegends", "\[Rule]", 
