Cell[CellGroupData[{

Cell["Logarithmic vote rate", "Subsection"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"akpoynz", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"indexes", ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"akpoy", "[", 
         RowBox[{"[", "#", "]"}], "]"}], ">", "0"}], "&&", 
       RowBox[{
        RowBox[{"kayitli", "[", 
         RowBox[{"[", "#", "]"}], "]"}], ">", 
        RowBox[{"akpoy", "[", 
         RowBox[{"[", "#", "]"}], "]"}]}]}], "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"logvr", "=", 
   RowBox[{"N", "[", 
    RowBox[{"Log", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"kayitli", "-", "akpoy"}], ")"}], "[", 
       RowBox[{"[", "akpoynz", "]"}], "]"}], "/", 
      RowBox[{"akpoy", "[", 
       RowBox[{"[", "akpoynz", "]"}], "]"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Mu]logvr", "=", 
   RowBox[{"Mean", "[", "logvr", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Sigma]logvr", "=", 
   RowBox[{"StandardDeviation", "[", "logvr", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"logvrs", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"logvr", "-", "\[Mu]logvr"}], ")"}], "/", "\[Sigma]logvr"}]}], 
  ";"}]}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Histogram", "[", 
  RowBox[{
  "logvrs", ",", "Automatic", ",", "\"\<Probability\>\"", ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLabel", "\[Rule]", 
    RowBox[{"sehir", "<>", "\"\< - Logaritmik oy oran\[DotlessI]\>\""}]}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*SubscriptBox[\(\[Nu]\), \(i\)]\)\>\"", ",", 
      "\"\<sand\[DotlessI]k oran\[DotlessI]\>\""}], "}"}]}]}], "]"}]], "Input"],

