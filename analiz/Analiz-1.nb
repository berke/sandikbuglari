Cell[BoxData[{
 RowBox[{
  RowBox[{"akpcum", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"katilimB", "[", 
       RowBox[{"[", "katilimBo", "]"}], "]"}], ",", 
      RowBox[{"Accumulate", "[", 
       RowBox[{"akpoyB", "[", 
        RowBox[{"[", "katilimBo", "]"}], "]"}], "]"}]}], "}"}], 
    "\[Transpose]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"akpcumga", "=", 
   RowBox[{"GatherBy", "[", 
    RowBox[{"akpcum", ",", 
     RowBox[{
      RowBox[{"Round", "[", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", "0.001"}], "]"}], "&"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"akpcumgam", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{"Mean", "[", 
        RowBox[{"#", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "}"}], "&"}], "/@",
     "akpcumga"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"akpcumgamf", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{"akpcumgam", ",", 
     RowBox[{"InterpolationOrder", "\[Rule]", "1"}]}], "]"}]}], 
  ";"}]}], "Input"],

