Cell[BoxData[{
 RowBox[{
  RowBox[{"indexesA", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"1", ",", 
     RowBox[{"Length", "[", "aalant", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"katilimG", "=", 
   RowBox[{"GatherBy", "[", 
    RowBox[{"indexesA", ",", 
     RowBox[{
      RowBox[{"katilimA", "[", 
       RowBox[{"[", "#", "]"}], "]"}], "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"akpoyB", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Total", "[", 
        RowBox[{"akpoyA", "[", 
         RowBox[{"[", "#", "]"}], "]"}], "]"}], "/", "toplamoy"}], ")"}], 
     "&"}], "/@", "katilimG"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"chpoyB", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Total", "[", 
        RowBox[{"chpoyA", "[", 
         RowBox[{"[", "#", "]"}], "]"}], "]"}], "/", "toplamoy"}], ")"}], 
     "&"}], "/@", "katilimG"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"katilimB", "=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Total", "[", 
        RowBox[{"kullananA", "[", 
         RowBox[{"[", "#", "]"}], "]"}], "]"}], "/", 
       RowBox[{"Total", "[", 
        RowBox[{"kayitliA", "[", 
         RowBox[{"[", "#", "]"}], "]"}], "]"}]}], ")"}], "&"}], "/@", 
    "katilimG"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"katilimBo", "=", 
   RowBox[{"Ordering", "[", "katilimB", "]"}]}], ";"}]}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"x", "=", 
  RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"katilimB", "[", 
          RowBox[{"[", "katilimBo", "]"}], "]"}], ",", 
         RowBox[{"Accumulate", "[", 
