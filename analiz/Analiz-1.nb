Cell[CellGroupData[{

Cell["AKP vs CHP neighbourhoods", "Subsection"],

Cell["\<\
First, gather votes by polling station:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"aalan", "=", 
   RowBox[{"GatherBy", "[", 
    RowBox[{"a", ",", 
     RowBox[{
      RowBox[{"#", "[", 
       RowBox[{"[", "4", "]"}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"aalant", "=", 
   RowBox[{
    RowBox[{"Function", "[", 
     RowBox[{"a", ",", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"a", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", 
           RowBox[{"1", ";;", "7"}]}], "]"}], "]"}], ",", 
        RowBox[{"Total", "[", 
         RowBox[{"a", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", 
            RowBox[{"8", ";;"}]}], "]"}], "]"}], "]"}]}], "]"}]}], "]"}], "/@",
     "aalan"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "ilA", ",", "ilceA", ",", "sandikA", ",", "alanA", ",", "datevalueA", ",",
      "timevalueA", ",", "urlA", ",", "kayitliA", ",", "kullananA", ",", 
     "kanunA", ",", "toplamA", ",", "itirazsizA", ",", "itirazliA", ",", 
     "gecerlioyA", ",", "gecersizoyA", ",", "dspoyA", ",", "dypoyA", ",", 
     "turkoyA", ",", "hkpoyA", ",", "bbpoyA", ",", "akpoyA", ",", "dpoyA", 
     ",", "mpoyA", ",", "spoyA", ",", "ldpoyA", ",", "btpoyA", ",", "hdpoyA", 
     ",", "chpoyA", ",", "mhpoyA", ",", "yurtpoyA", ",", "ipoyA", ",", 
     "hakparoyA", ",", "heparoyA", ",", "gpoyA", ",", "tkpoyA", ",", "odpoyA",
      ",", "apoyA", ",", "bdpoyA", ",", "mypoyA", ",", "emepoyA", ",", 
     "hudaparoyA"}], "}"}], "=", 
   RowBox[{"aalant", "\[Transpose]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"katilimA", "=", 
   RowBox[{"kullananA", "/", "kayitliA"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"katilimAord", "=", 
   RowBox[{"Ordering", "[", "katilimA", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"akpoyAcum", "=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"akpoyA", "[", 
     RowBox[{"[", "katilimAord", "]"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"chpoyAcum", "=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"chpoyA", "[", 
     RowBox[{"[", "katilimAord", "]"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"akpchpoyfarkAcum", "=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"akpoyA", "-", "chpoyA"}], ")"}], "[", 
     RowBox[{"[", "katilimAord", "]"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"toplamoy", "=", 
  RowBox[{"N", "[", 
   RowBox[{"Total", "[", "toplam", "]"}], "]"}]}]}], "Input"],

Cell[BoxData["3.283852`*^6"], "Output"]
}, Open  ]],

